# CryoTrader — Local Secrets & Dev Settings
#
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control!
#
# This file serves two purposes:
#   1. API credentials vault — slot_config.py reads these by env var name
#      (referenced in accounts.toml)
#   2. Local dev defaults — used when running `python main.py` directly
#
# For slot deployments, see: slots/slot-XX.toml + accounts.toml

# =============================================================================
# LOCAL DEV SETTINGS
# =============================================================================
DEPLOYMENT_TARGET=development
EXCHANGE=coincall
TRADING_ENVIRONMENT=testnet

# =============================================================================
# COINCALL CREDENTIALS
# =============================================================================
COINCALL_API_KEY_TEST=your_testnet_api_key_here
COINCALL_API_SECRET_TEST=your_testnet_api_secret_here

COINCALL_API_KEY_PROD=your_production_api_key_here
COINCALL_API_SECRET_PROD=your_production_api_secret_here

# Subaccount (optional)
COINCALL_API_KEY_PRODSUB=your_subaccount_api_key_here
COINCALL_API_SECRET_PRODSUB=your_subaccount_api_secret_here

# =============================================================================
# DERIBIT CREDENTIALS
# =============================================================================
DERIBIT_CLIENT_ID_TEST=your_deribit_testnet_client_id
DERIBIT_CLIENT_SECRET_TEST=your_deribit_testnet_client_secret

DERIBIT_CLIENT_ID_PROD=your_deribit_production_client_id
DERIBIT_CLIENT_SECRET_PROD=your_deribit_production_client_secret

# =============================================================================
# TELEGRAM NOTIFICATIONS
# =============================================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# =============================================================================
# DASHBOARD (local dev)
# =============================================================================
DASHBOARD_PASSWORD=changeme
DASHBOARD_PORT=8080